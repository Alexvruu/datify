---
import { getCollection, render, type CollectionEntry } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }))
}

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { Content } = await render(post)

const { title, description, date, author, tags, image } = post.data
const canonicalURL = new URL(Astro.url.pathname, Astro.site)

function formatDate(d: Date) {
  return d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })
}

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: {
    '@type': 'Person',
    name: author,
    url: 'https://datify.fr',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Datify',
    url: 'https://datify.fr',
    logo: {
      '@type': 'ImageObject',
      url: 'https://datify.fr/og-default.jpg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL.toString(),
  },
  ...(image ? { image: new URL(image, Astro.site).toString() } : {}),
  keywords: tags.join(', '),
  inLanguage: 'fr-FR',
}
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />

  <article class="py-20">
    <div class="container max-w-2xl">

      <!-- Header -->
      <header class="mb-12">
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map((tag) => (
            <span class="text-xs bg-[#EEF2FF] text-[#635BFF] px-3 py-1 rounded-full font-medium">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="text-[#0A2540] mb-6">{title}</h1>

        <p class="text-lg text-[#425466] mb-8 leading-relaxed">{description}</p>

        <div class="flex items-center gap-4 py-6 border-y border-[#E2E8F0] text-sm text-[#8898AA]">
          <div class="w-9 h-9 bg-[#EEF2FF] rounded-full flex items-center justify-center text-[#635BFF] font-bold text-sm shrink-0">
            AG
          </div>
          <div>
            <span class="font-medium text-[#0A2540]">{author}</span>
            <span class="mx-2">·</span>
            <time datetime={date.toISOString()}>{formatDate(date)}</time>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="prose">
        <Content />
      </div>

      <!-- Footer -->
      <footer class="mt-16 pt-10 border-t border-[#E2E8F0]">
        <div class="bg-[#F6F8FA] rounded-xl p-8">
          <p class="text-sm font-semibold text-[#0A2540] mb-2">Vous avez un projet analytics ?</p>
          <p class="text-sm text-[#425466] mb-5">
            Je mets en place ce type de tracking au quotidien. Discutons de votre situation.
          </p>
          <a href="/contact" class="btn-primary text-sm py-2.5 px-5">Prendre contact →</a>
        </div>

        <div class="mt-8">
          <a href="/blog" class="text-sm text-[#635BFF] hover:text-[#4F46E5] font-medium">
            ← Retour au blog
          </a>
        </div>
      </footer>

    </div>
  </article>
</BaseLayout>

<style>
  .prose {
    color: #425466;
    line-height: 1.8;
    font-size: 1rem;
  }
  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0A2540;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: #0A2540;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(p) {
    margin-bottom: 1.25rem;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }
  .prose :global(li) {
    margin-bottom: 0.5rem;
  }
  .prose :global(ul li) {
    list-style-type: disc;
  }
  .prose :global(ol li) {
    list-style-type: decimal;
  }
  .prose :global(code) {
    background: #F6F8FA;
    border: 1px solid #E2E8F0;
    color: #635BFF;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  .prose :global(pre) {
    background: #0A2540;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    color: #e2e8f0;
    padding: 0;
    font-size: 0.875rem;
  }
  .prose :global(blockquote) {
    border-left: 3px solid #635BFF;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: #425466;
    font-style: italic;
  }
  .prose :global(a) {
    color: #635BFF;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) {
    color: #4F46E5;
  }
  .prose :global(strong) {
    font-weight: 600;
    color: #0A2540;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .prose :global(th) {
    background: #F6F8FA;
    border: 1px solid #E2E8F0;
    padding: 0.6rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #0A2540;
  }
  .prose :global(td) {
    border: 1px solid #E2E8F0;
    padding: 0.6rem 1rem;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid #E2E8F0;
    margin: 2rem 0;
  }
</style>
