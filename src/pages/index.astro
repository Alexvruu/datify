---
import BaseLayout from '../layouts/BaseLayout.astro'

const marqueeItems = [
  'GA4', 'Google Tag Manager', 'Meta Ads', 'BigQuery', 'dbt', 'Looker Studio',
  'Google Ads', 'Shopify', 'Consent Mode v2', 'Server-Side Tagging', 'Attribution',
]

const steps = [
  {
    n: '01',
    title: 'Audit & Diagnostic',
    desc: 'J\'analyse votre tracking, identifie chaque perte de données et vous rends un rapport clair — ce qui casse, pourquoi, et comment le corriger.',
  },
  {
    n: '02',
    title: 'Implémentation',
    desc: 'Mise en place GA4, GTM server-side, pipelines BigQuery ou campagnes media. Livraison documentée, testée, prête à l\'emploi.',
  },
  {
    n: '03',
    title: 'Activation',
    desc: 'Vos données travaillent pour vous. ROAS en hausse, reportings automatisés, équipes autonomes. Je reste disponible pour optimiser.',
  },
]

const services = [
  {
    icon: '◈',
    title: 'Analytics & Tracking',
    desc: 'GA4, GTM server-side, Consent Mode v2. Des données fiables malgré les bloqueurs, conformes RGPD.',
    tags: ['GA4', 'GTM', 'Server-side'],
    href: '/services',
  },
  {
    icon: '⬡',
    title: 'Data Engineering',
    desc: 'Pipelines BigQuery, modélisation dbt, dashboards Looker Studio. De la donnée brute aux décisions actionnables.',
    tags: ['BigQuery', 'dbt', 'Looker'],
    href: '/services',
  },
  {
    icon: '◎',
    title: 'Média Buying',
    desc: 'Meta Ads & Google Ads avec attribution fiable. Chaque euro de budget est tracé, mesuré, optimisé.',
    tags: ['Meta Ads', 'Google Ads', 'ROAS'],
    href: '/services',
  },
  {
    icon: '◇',
    title: 'Reporting & Audit',
    desc: 'Audit de votre stack analytics, dashboards sur mesure, formation équipes. La data rendue lisible par tous.',
    tags: ['Audit', 'Dashboards', 'Formation'],
    href: '/services',
  },
]

const testimonials = [
  {
    quote: 'Avant, on perdait 35% de nos conversions dans GA4. Après 3 semaines avec Alexandre, on est à 97% de tracking fiable. Notre ROAS Meta est passé de 1.9× à 3.2×.',
    name: 'Sophie M.',
    role: 'Head of Growth · E-commerce mode',
    initials: 'SM',
    kpi: '+68% ROAS',
  },
  {
    quote: 'Le pipeline BigQuery + dbt a divisé par 3 le temps de préparation de nos reportings. On décide en minutes, plus en jours.',
    name: 'Thomas R.',
    role: 'Directeur Marketing · SaaS B2B',
    initials: 'TR',
    kpi: '−70% temps reporting',
  },
]
---

<BaseLayout
  title="Analytics Engineer & Media Buyer Freelance"
  description="Datify — Analytics engineering, tracking GA4 server-side et media buying. Des données fiables, des décisions qui performent."
>

  <!-- ═══════════ HERO ═══════════ -->
  <section class="relative min-h-[calc(100vh-72px)] flex flex-col justify-center pt-20 pb-16 overflow-hidden">

    <!-- Subtle background gradient -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div style="position:absolute;top:-20%;right:-10%;width:60vw;height:60vw;max-width:900px;max-height:900px;border-radius:50%;background:radial-gradient(circle,rgba(99,91,255,0.06) 0%,transparent 70%);"></div>
    </div>

    <div class="container relative z-10">
      <!-- Label -->
      <p class="reveal label mb-8">
        Analytics · Data Engineering · Media Buying
      </p>

      <!-- H1 -->
      <h1 class="reveal d1 mb-8">
        Data-driven.<br />
        <span class="text-[#635BFF]">Résultats</span><br />
        prouvés.
      </h1>

      <!-- Subtitle -->
      <p class="reveal d2 text-lg md:text-xl text-[#425466] max-w-xl mb-12 leading-relaxed">
        Analytics engineering, tracking GA4 server-side & media buying — pour des équipes qui décident sur de vraies données.
      </p>

      <!-- CTAs -->
      <div class="reveal d3 flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary text-base">
          Démarrer un projet →
        </a>
        <a href="/services" class="btn-ghost text-base">
          Voir les services
        </a>
      </div>

      <!-- Stats strip -->
      <div class="reveal d4 grid grid-cols-2 md:grid-cols-4 gap-8 mt-20 pt-10 border-t border-[#E2E8F0]">
        {[
          { v: '+40', l: 'projets livrés' },
          { v: '3×', l: 'ROAS moyen' },
          { v: '97%', l: 'données récupérées' },
          { v: '< 24h', l: 'délai de réponse' },
        ].map(({ v, l }) => (
          <div>
            <div class="text-2xl md:text-3xl font-bold text-[#0A2540]">{v}</div>
            <div class="text-sm text-[#8898AA] mt-1">{l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ MARQUEE ═══════════ -->
  <div class="border-y border-[#E2E8F0] py-5 overflow-hidden bg-white">
    <div class="marquee-track select-none" aria-hidden="true">
      {[...marqueeItems, ...marqueeItems].map((item) => (
        <span class="inline-flex items-center gap-5 px-6 text-sm font-medium text-[#8898AA] whitespace-nowrap">
          {item}
          <span class="w-1 h-1 rounded-full bg-[#635BFF] opacity-50"></span>
        </span>
      ))}
    </div>
  </div>

  <!-- ═══════════ HOW IT WORKS ═══════════ -->
  <section class="py-32 bg-white">
    <div class="container">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-20">
        <div>
          <p class="reveal label mb-4">Méthode</p>
          <h2 class="reveal d1">Comment<br />ça marche</h2>
        </div>
        <p class="reveal d2 text-[#425466] max-w-sm md:text-right">
          Un process en 3 étapes, transparent et sans surprise.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-px bg-[#E2E8F0]">
        {steps.map((step, i) => (
          <div class={`reveal d${i + 1} bg-white p-10 md:p-12`}>
            <span class="text-5xl font-black text-[#E2E8F0] block mb-8 leading-none select-none">
              {step.n}
            </span>
            <h3 class="text-[#0A2540] mb-4 text-xl">{step.title}</h3>
            <p class="text-[#425466] text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ SERVICES ═══════════ -->
  <section class="py-32 bg-[#F6F8FA]">
    <div class="container">
      <div class="mb-20">
        <p class="reveal label mb-4">Services</p>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
          <h2 class="reveal d1">Ce que je<br />fais pour vous</h2>
          <a href="/services" class="reveal d2 btn-ghost self-start md:self-auto">
            Voir tous les services →
          </a>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {services.map((s, i) => (
          <a
            href={s.href}
            class={`reveal d${(i % 2) + 1} group bg-white rounded-2xl p-10 border border-transparent hover:border-[#635BFF] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl`}
          >
            <div class="flex items-start justify-between mb-8">
              <div class="w-12 h-12 rounded-xl bg-[#EEF2FF] flex items-center justify-center text-[#635BFF] text-xl group-hover:bg-[#635BFF] group-hover:text-white transition-all duration-300">
                {s.icon}
              </div>
              <span class="text-[#635BFF] text-xl translate-x-0 group-hover:translate-x-1 transition-transform duration-300 opacity-0 group-hover:opacity-100">→</span>
            </div>
            <h3 class="text-[#0A2540] mb-3">{s.title}</h3>
            <p class="text-sm text-[#425466] leading-relaxed mb-6">{s.desc}</p>
            <div class="flex gap-2 flex-wrap">
              {s.tags.map((tag) => (
                <span class="text-xs bg-[#F6F8FA] border border-[#E2E8F0] text-[#8898AA] px-3 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ TESTIMONIALS ═══════════ -->
  <section class="py-32 bg-white">
    <div class="container">
      <div class="mb-20">
        <p class="reveal label mb-4">Résultats</p>
        <h2 class="reveal d1">Ce que ça<br />change vraiment</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {testimonials.map((t, i) => (
          <div class={`reveal d${i + 1} bg-[#F6F8FA] rounded-2xl p-10 md:p-12 flex flex-col justify-between min-h-[320px]`}>
            <div>
              <p class="text-4xl font-serif text-[#635BFF] leading-none mb-6 select-none">"</p>
              <p class="text-[#0A2540] text-lg font-medium leading-relaxed mb-8">
                {t.quote}
              </p>
            </div>
            <div class="flex items-center justify-between gap-4 pt-8 border-t border-[#E2E8F0]">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-[#635BFF] flex items-center justify-center text-white text-xs font-bold shrink-0">
                  {t.initials}
                </div>
                <div>
                  <p class="text-sm font-semibold text-[#0A2540]">{t.name}</p>
                  <p class="text-xs text-[#8898AA]">{t.role}</p>
                </div>
              </div>
              <span class="text-xs font-bold text-[#635BFF] bg-[#EEF2FF] px-3 py-1.5 rounded-full shrink-0">
                {t.kpi}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ CTA ═══════════ -->
  <section class="py-32 bg-[#0A2540]">
    <div class="container text-center">
      <p class="reveal label text-white/30 mb-6">On démarre ?</p>
      <h2 class="reveal d1 text-white mb-6">
        Prêt à décider<br />sur de vraies données ?
      </h2>
      <p class="reveal d2 text-white/50 max-w-md mx-auto mb-12 text-lg leading-relaxed">
        Premier échange gratuit et sans engagement. Je réponds sous 24h.
      </p>
      <div class="reveal d3 flex flex-wrap gap-4 justify-center">
        <a href="/contact" class="btn-primary text-base">
          Prendre contact →
        </a>
        <a href="/blog" style="display:inline-flex;align-items:center;gap:0.5rem;border:1.5px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);padding:0.875rem 1.75rem;border-radius:100px;font-weight:500;font-size:0.9375rem;transition:all 0.2s ease;" onmouseover="this.style.borderColor='rgba(255,255,255,0.5)';this.style.color='white'" onmouseout="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='rgba(255,255,255,0.7)'">
          Lire le blog
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
